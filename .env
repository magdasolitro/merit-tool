# ──────────────────────────────────────────────────────────────────────────────
# X-REG — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored and never baked into the Docker image.
# ──────────────────────────────────────────────────────────────────────────────

SSH_KEY=~/.ssh/id_rsa
SSH_USER=xreg-user